# Copy to server/.env and fill in real values. DO NOT COMMIT .env.

# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/ecoleos

# Port the API listens on
PORT=4000

# JWT signing secrets — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_48_random_bytes_hex
JWT_REFRESH_SECRET=replace_with_another_48_random_bytes_hex

# Super admin credentials (server-side only)
SUPER_USER=superadmin
SUPER_PASS=replace_with_a_strong_unique_password

# Secret used to sign/verify ÉcoleOS license keys.
# Must match the secret used by generate-license.js.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
ECOLEOS_LICENSE_SECRET=replace_with_48_random_bytes_hex

# Comma-separated list of origins allowed to call the API from the browser.
# Example: https://app.ecoleos.com,https://admin.ecoleos.com
CORS_ORIGINS=http://localhost:5173
